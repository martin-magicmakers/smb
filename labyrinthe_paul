def deplacement_ennemi(declenchement, ennemi_x, ennemi_y):
    if declenchement:
        directions = ["droite","gauche","haut","bas"]
        random.shuffle(directions)
        for direction in directions:
            if direction == "droite":
                if ((ennemi_x + cellule)//cellule, ennemi_y//cellule) not in murs:
                    return "droite"
            if direction == "gauche":
                if ((ennemi_x - cellule)//cellule, ennemi_y//cellule) not in murs:
                    return "gauche"
            if direction == "bas":
                if (ennemi_x//cellule, (ennemi_y + cellule)//cellule) not in murs:
                    return "bas"
            if direction == "haut":
                if (ennemi_x//cellule, (ennemi_y - cellule)//cellule) not in murs:
                    return "haut"
    return None

